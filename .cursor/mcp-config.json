{
  "version": "1.0",
  "name": "smartcont-automations",
  "description": "Automações para o projeto SmartCont",
  "commands": {
    "deploy": {
      "description": "Faz deploy automático para Vercel",
      "command": "vercel deploy --prod",
      "requiresAuth": true,
      "preDeploy": [
        "npm run lint",
        "npm test",
        "npm run build"
      ],
      "errorHandling": {
        "lint": "npm run lint:fix",
        "test": "npm run test:fix",
        "build": "npm run build:fix"
      }
    },
    "build": {
      "description": "Executa o build do projeto",
      "command": "npm run build",
      "requiresAuth": false
    },
    "test": {
      "description": "Executa os testes",
      "command": "npm test",
      "requiresAuth": false
    },
    "lint": {
      "description": "Executa o linter",
      "command": "npm run lint",
      "requiresAuth": false
    },
    "analisar-vercel": {
      "description": "Analisa a configuração e status do projeto na Vercel",
      "command": "vercel project ls && vercel env ls",
      "requiresAuth": true
    },
    "corrigir-erros": {
      "description": "Analisa e tenta corrigir erros automaticamente",
      "command": "npm run lint:fix && npm run test:fix && npm run build:fix",
      "requiresAuth": false,
      "errorTypes": {
        "lint": "Erros de estilo e padrão de código",
        "test": "Falhas nos testes",
        "build": "Erros de compilação",
        "deploy": "Problemas no deploy"
      }
    }
  },
  "github": {
    "enabled": true,
    "autoSync": true,
    "branch": "main"
  },
  "vercel": {
    "enabled": true,
    "autoDeploy": true,
    "projectId": "smartcont-automations"
  },
  "render": {
    "enabled": true,
    "autoDeploy": true,
    "serviceId": "smartcont-automations"
  }
} 